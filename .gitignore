# ─── Signing key material — NEVER commit (IP-safety boundary, ships-publicly-vs-never.md) ───
*.p12
*.pfx
*.pem
*.key
*.cer
*.crt
*.p8
*.keystore
*.jks
AuthKey_*.p8
DeveloperID*.cer
*.provisionprofile
*.mobileprovision
*notarization*.json
*app-store-connect*.json
*.spc
*.pvk

# ─── Secrets / env files — secrets live in CI secrets / HSM / Key Vault only ───
.env
.env.*
*.secret
secrets.toml
secrets.yaml
credentials.json

# ─── App source / binary build inputs (binaries are consumed as release artifacts) ───
# The framework never vendors app source; built binaries are fetched, not committed.
binaries/
inputs/
*.exe
*.app/
*.dll
*.dylib
*.so

# ─── Build / packaging output ───
target/
dist/
out/
build/
*.msi
*.dmg
*.AppImage
*.deb
*.rpm
*.nsis.exe
*-setup.exe

# ─── OS cruft ───
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# ─── Generated brand raster assets (regenerated from SVG sources by gen-assets) ───
# Only the SVG sources (icon.svg, dmg-background.svg, banner.svg, footer.svg) are
# committed; raster outputs are regenerated on demand by branding/gen-assets.sh.
branding/icons/
branding/generated/
branding/nsis-header.bmp
branding/nsis-sidebar.bmp
branding/dmg-background.png
branding/*/icon-256.png
branding/*/icon.ico
branding/*/icon.icns

# Python bytecode
__pycache__/
*.pyc

# ─── Agent-session runtime state — never part of the publishable surface ───
.s4f3-data/
.claude-data/
